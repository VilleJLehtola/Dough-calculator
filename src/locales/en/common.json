    "items": {
      "autolyse": {
        "title": "Autolyse",
        "desc": "Letting flour and water rest before adding salt and starter. Improves gluten development and dough extensibility."
      },
      "levain": {
        "title": "Levain / Starter %",
        "desc": "The portion of prefermented flour used in the dough. Higher % speeds fermentation, lower % slows it."
      },
      "stretch_fold": {
        "title": "Stretch & fold",
        "desc": "A folding method during bulk fermentation to strengthen gluten without kneading. Usually done every 30–60 minutes."
      },
      "bulk": {
        "title": "Bulk fermentation",
        "desc": "The first rise after mixing, when the dough develops flavor and strength."
      },
      "cold": {
        "title": "Cold fermentation",
        "desc": "Letting dough rise slowly in the fridge. Enhances flavor and makes timing more flexible."
      },
      "scoring": {
        "title": "Scoring",
        "desc": "Cutting the dough surface before baking to control expansion and create patterns."
      },
      "hydration": {
        "title": "Hydration %",
        "desc": "Ratio of water to flour. Higher hydration = wetter, more open crumb; lower hydration = tighter, easier to handle."
      }
    }
  }
